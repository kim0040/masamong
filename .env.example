# ----------------------------------------------------
# 1. 공통 및 기본 API 세팅
# ----------------------------------------------------
DISCORD_BOT_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# NanoGPT (메인 레인 주 모델)
NANOGPT_KEY=your_nanogpt_key_here
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1

# CometAPI (라우팅 주 모델 및 메인 대체 모델)
COMETAPI_KEY=your_cometapi_key_here
COMETAPI_BASE_URL=https://api.cometapi.com/v1
USE_COMETAPI=true

# 이전 기본 Gemini API 키 (선택 사항)
GEMINI_API_KEY=your_gemini_api_key_here
ALLOW_DIRECT_GEMINI_FALLBACK=false

# ----------------------------------------------------
# 2. Main 레인 (답변 생성 - NanoGPT Primary, CometAPI Fallback)
# ----------------------------------------------------
LLM_MAIN_PRIMARY_PROVIDER=openai_compat
LLM_MAIN_PRIMARY_MODEL=deepseek-ai/deepseek-v3.2-exp
LLM_MAIN_PRIMARY_BASE_URL=${NANOGPT_BASE_URL}
LLM_MAIN_PRIMARY_API_KEY=${NANOGPT_KEY}

LLM_MAIN_FALLBACK_PROVIDER=openai_compat
LLM_MAIN_FALLBACK_MODEL=DeepSeek-V3.2-Exp-nothinking
LLM_MAIN_FALLBACK_BASE_URL=${COMETAPI_BASE_URL}
LLM_MAIN_FALLBACK_API_KEY=${COMETAPI_KEY}

# ----------------------------------------------------
# 3. Routing 레인 (웹 검색, 의도 분석 - CometAPI Primary)
# ----------------------------------------------------
LLM_ROUTING_PRIMARY_PROVIDER=openai_compat
LLM_ROUTING_PRIMARY_MODEL=gemini-3.1-flash-lite-preview
LLM_ROUTING_PRIMARY_BASE_URL=${COMETAPI_BASE_URL}
LLM_ROUTING_PRIMARY_API_KEY=${COMETAPI_KEY}

# ----------------------------------------------------
# 4. 이미지 생성 모델 (CometAPI / NanoGPT 스위치 가능)
# ----------------------------------------------------
# [✔︎ 당장 사용하는 옵션] CometAPI 사용
COMETAPI_IMAGE_ENABLED=true
COMETAPI_IMAGE_API_KEY=${COMETAPI_KEY}
COMETAPI_IMAGE_BASE_URL=${COMETAPI_BASE_URL}

# [■ 나중에 변경할 옵션] NanoGPT 사용
# 위 3줄을 주석 처리하고 아래 3줄의 주석을 푸세요.
# COMETAPI_IMAGE_ENABLED=true
# COMETAPI_IMAGE_API_KEY=${NANOGPT_KEY}
# COMETAPI_IMAGE_BASE_URL=${NANOGPT_BASE_URL}

IMAGE_MODEL=gemini-3.1-flash-image
# ----------------------------------------------------
# 5. 날씨 및 기타 통합 API
# ----------------------------------------------------
KMA_API_KEY=your_kma_api_key_here
FINNHUB_API_KEY=your_finnhub_api_key_here
KAKAO_API_KEY=your_kakao_api_key_here
GOOGLE_CX=your_google_cx_here

# ----------------------------------------------------
# 6. Database Server Setup (External DB / TiDB)
# ----------------------------------------------------
MASAMONG_DB_BACKEND=tidb
MASAMONG_DB_HOST=your_db_host_here
MASAMONG_DB_PORT=4000
MASAMONG_DB_NAME=masamong
MASAMONG_DB_USER=your_db_user_here
MASAMONG_DB_PASSWORD=your_db_password_here
MASAMONG_DB_SSL_CA=/etc/ssl/certs/ca-certificates.crt
MASAMONG_DB_SSL_VERIFY_IDENTITY=true
MASAMONG_DB_STRICT_REMOTE_ONLY=true

MASAMONG_DB_CONN_MAX_LIFETIME_SECONDS=600
MASAMONG_DB_CONNECT_TIMEOUT=10
MASAMONG_DB_READ_TIMEOUT=30
MASAMONG_DB_WRITE_TIMEOUT=30

DISCORD_EMBEDDING_BACKEND=tidb
KAKAO_STORE_BACKEND=tidb
DISCORD_EMBEDDING_TIDB_TABLE=discord_chat_embeddings
KAKAO_TIDB_TABLE=kakao_chunks

# ----------------------------------------------------
# 7. 기타 설정
# ----------------------------------------------------
LOCAL_EMBEDDING_LOCAL_FILES_ONLY=true
RAG_ARCHIVE_RUN_ON_STARTUP=false
RAG_ARCHIVE_STARTUP_DELAY_SECONDS=120

EMB_CONFIG_PATH=/mnt/block-storage/masamong/tmp/server_config/emb_config.server.json
PROMPT_CONFIG_PATH=/mnt/block-storage/masamong/tmp/server_config/prompts.server.json

STRUCTURED_MEMORY_QUERY_LIMIT=800
STRUCTURED_MEMORY_FALLBACK_QUERY_LIMIT=2000
STRUCTURED_MEMORY_SIMILARITY_THRESHOLD=0.5

# 이 파일은 봇을 실행하는 데 필요한 환경 변수의 예시입니다.
# 이 파일의 이름을 `.env`로 복사한 뒤, 각 변수에 실제 키 값을 채워넣으세요.

# --- 필수 API 키 ---

# Discord 봇 토큰
# Discord 개발자 포털(https://discord.com/developers/applications)에서 발급받을 수 있습니다.
DISCORD_BOT_TOKEN="YOUR_DISCORD_BOT_TOKEN_HERE"

# Google Gemini API 키
# Google AI Studio(https://aistudio.google.com/app/apikey)에서 발급받을 수 있습니다.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# CometAPI 키
COMETAPI_KEY="YOUR_COMETAPI_KEY_HERE"
COMETAPI_BASE_URL="https://api.cometapi.com/v1"
USE_COMETAPI="true"
INTENT_LLM_ENABLED="true"
INTENT_LLM_RAG_STRONG_BYPASS="true"
AUTO_WEB_SEARCH_COOLDOWN_SECONDS="90"
AUTO_WEB_SEARCH_ALLOW_SHORT_FOLLOWUP="false"

# 구조형 설정 파일 경로
# 서버 전용 설정은 Git 제외 JSON 파일로 분리하는 것을 권장합니다.
EMB_CONFIG_PATH="/home/ubuntu/masamong/tmp/server_config/emb_config.server.json"
PROMPT_CONFIG_PATH="/home/ubuntu/masamong/tmp/server_config/prompts.server.json"

# --- TiDB / 중앙 DB 설정 (선택 사항) ---
# sqlite 유지 시 MASAMONG_DB_BACKEND=sqlite
# TiDB 사용 시 아래 항목을 모두 설정하세요.
MASAMONG_DB_BACKEND="sqlite"
# true면 로컬 sqlite 파일이 남아있어도 원격 TiDB 경로만 사용합니다.
MASAMONG_DB_STRICT_REMOTE_ONLY="false"
MASAMONG_DB_HOST="gateway01.ap-northeast-1.prod.aws.tidbcloud.com"
MASAMONG_DB_PORT="4000"
MASAMONG_DB_NAME="masamong"
MASAMONG_DB_USER="YOUR_TIDB_USER"
MASAMONG_DB_PASSWORD="YOUR_TIDB_PASSWORD"
MASAMONG_DB_SSL_CA="/etc/ssl/certs/ca-certificates.crt"
MASAMONG_DB_SSL_VERIFY_IDENTITY="true"

# Discord 임베딩 저장소
# sqlite: 기존 discord_embeddings.db 사용
# tidb: 중앙 TiDB의 discord_chat_embeddings 테이블 사용
DISCORD_EMBEDDING_BACKEND="sqlite"
DISCORD_EMBEDDING_TIDB_TABLE="discord_chat_embeddings"

# Kakao 저장소
# local: 기존 metadata.json + vectors.npy 사용
# tidb: 중앙 TiDB의 kakao_chunks 테이블 사용
KAKAO_STORE_BACKEND="local"
KAKAO_TIDB_TABLE="kakao_chunks"

# 구조화 메모리 저장 길이 제어
STRUCTURED_MEMORY_MAX_SUMMARY_CHARS="320"
STRUCTURED_MEMORY_MAX_CONTEXT_CHARS="1200"
STRUCTURED_USER_MEMORY_MIN_CHARS="12"
STRUCTURED_MEMORY_QUERY_LIMIT="800"
STRUCTURED_MEMORY_FALLBACK_QUERY_LIMIT="2000"
STRUCTURED_MEMORY_SIMILARITY_THRESHOLD="0.5"


# --- 도구(Tool) 기능 사용을 위한 API 키 (선택 사항) ---
# 아래 키들이 없으면 해당 기능은 작동하지 않습니다.

# 기상청 공공데이터포털 API 키 (날씨 정보용)
# https://www.data.go.kr/
KMA_API_KEY="YOUR_KMA_API_KEY_HERE"

# RAWG Video Games Database API 키 (게임 추천용)
# https://rawg.io/apidocs
RAWG_API_KEY="YOUR_RAWG_API_KEY_HERE"

# Finnhub API 키 (해외 주식 시세 및 뉴스용)
# https://finnhub.io/
FINNHUB_API_KEY="YOUR_FINNHUB_API_KEY_HERE"

# Kakao Developers REST API 키 (장소 검색용)
# https://developers.kakao.com/
KAKAO_API_KEY="YOUR_KAKAO_REST_API_KEY_HERE"

# 공공데이터포털(KRX) API 키 (국내 주식 시세용)
# https://www.data.go.kr/data/15094808/openapi.do
# 포털에서 발급받은 '일반 인증키 (Decoding)' 값을 그대로 입력하세요. URL 인코딩은 코드에서 자동으로 처리합니다.
KRX_API_KEY="YOUR_DECODED_KRX_API_KEY_HERE"

# 한국수출입은행 API 키 (환율 정보용)
# https://www.koreaexim.go.kr/ir/HPHKIR019M01
EXIM_API_KEY_KR="YOUR_EXIM_API_KEY_HERE"

# --- 알림/채널 기본 설정 ---
DEFAULT_LOCATION_NAME="광양"
DEFAULT_NX="73"
DEFAULT_NY="70"
ENABLE_RAIN_NOTIFICATION="false"
RAIN_NOTIFICATION_CHANNEL_ID="0"
WEATHER_CHECK_INTERVAL_MINUTES="60"
RAIN_NOTIFICATION_THRESHOLD_POP="30"
RAIN_NOTIFICATION_GREETING_THRESHOLD_POP="60"
ENABLE_GREETING_NOTIFICATION="false"
GREETING_NOTIFICATION_CHANNEL_ID="0"
ENABLE_EARTHQUAKE_ALERT="true"
EARTHQUAKE_CHECK_INTERVAL_MINUTES="1"
MORNING_GREETING_HOUR="7"
MORNING_GREETING_MINUTE="30"
EVENING_GREETING_HOUR="23"
EVENING_GREETING_MINUTE="50"

# prompts JSON이 없을 때만 사용하는 단순 fallback 채널 목록
# DEFAULT_AI_CHANNELS="123456789012345678,234567890123456789"

# --- 여행 어시스턴트 기능용 API 키 ---

# OpenWeatherMap API 키 (해외 날씨용)
# https://openweathermap.org/api
OPENWEATHERMAP_API_KEY="YOUR_OPENWEATHERMAP_API_KEY"

# Foursquare API 키 (장소 추천용)
# https://location.foursquare.com/developer/
FOURSQUARE_API_KEY="YOUR_FOURSQUARE_API_KEY"

# Ticketmaster API 키 (이벤트 정보용)
# https://developer.ticketmaster.com/
TICKETMASTER_API_KEY="YOUR_TICKETMASTER_API_KEY"
